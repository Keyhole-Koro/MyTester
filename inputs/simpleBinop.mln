i32 main() {
    i32 a = 1;
    i32 b = 0;
    i32 c = 1;

    // (a && b) || c → (1 && 0) || 1 → 0 || 1 → 1
    i32 x = (a && b) || c;

    // a && (b || c) → 1 && (0 || 1) → 1 && 1 → 1
    i32 y = a && (b || c);

    // a || (b && c) → 1 || (0 && 1) → 1 || 0 → 1
    i32 z = a || (b && c);

    return x + y + z; // 1 + 1 + 1 = 3
}
