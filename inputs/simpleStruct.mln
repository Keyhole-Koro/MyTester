typedef struct {
    i32 x;
    i32 y;
} Point;

void translate(Point *p, i32 dx, i32 dy) {
    p->x = p->x + dx;
    p->y = p->y + dy;
}

i32 sum(Point *p) {
    return p->x + p->y;
}

i32 main() {
    Point p;
    p.x = 1;
    p.y = 2;

    translate(&p, 3, 4); // p becomes (4,6)
    return sum(&p);      // 10
}
