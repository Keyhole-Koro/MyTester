void increment(i32 *ptr) {
    *ptr = *ptr + 1;
}

void increment2(i32 **pp) {
    **pp = **pp + 1;
}

i32 main() {
    i32 x = 10;
    increment(&x); // x becomes 11
    increment(&x); // x becomes 12

    i32 *p = &x;
    increment2(&p);  // x becomes 13
    increment2(&p);  // x becomes 14
    return x;
}
